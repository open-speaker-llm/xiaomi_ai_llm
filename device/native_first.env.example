# native_first_client.sh 运行配置
#
# 复制到音箱的 /data/native_first.env 后再按实际环境修改：
#   cp /data/native_first.env.example /data/native_first.env

# Mac 服务端
SERVER=http://192.168.8.150:8080
BACKEND=deepseek
VAD_SCRIPT=/data/vad_record.sh
STREAM_TIMEOUT=180

# 运行时文件
LOG_FILE=/tmp/native_first_client.log
PID_FILE=/tmp/native_first_client.pid

# LLM TTS 播放音量。
# auto 会根据小米原生媒体音量或当前 Master 音量，映射出更适合 LLM 播放的 Master 音量。
LLM_VOLUME=1.2
LLM_MASTER_VOLUME=auto
LLM_MASTER_SCALE=145
LLM_MASTER_CURRENT_SCALE=112
LLM_MASTER_MIN=96
LLM_MASTER_MAX=196

# 小米原生结果轮询。
NATIVE_RESULT_SOURCE=auto
NATIVE_WAIT_SECONDS=12
NATIVE_POLL_INTERVAL=0.2
NATIVE_UBUS_TIMEOUT=1
WAKE_EVENT_MAX_AGE=4
WAKE_IGNORE_QUERIES="小爱同学 小爱 小爱小爱 小爱同学小爱同学 我在 在呢"
WAKE_ON_THINK_SYSTEM1=1
# boot1/system1 上 mibrain nlp_result_get 可能不刷新，原生 ASR/TTS 指令会写入该日志。
# auto 模式下，boot0 使用 ubus_nlp_result，boot1 使用 aivs_lab_instruction。
NATIVE_AIVS_LAB_RESULT_SYSTEM1=1
# boot1 原生支持的命令可能不产生 instruction.log fallback 结果。
# 因此 boot1 只短时间观察“不支持/呼叫 DeepSeek”等 fallback 结果，避免占住下一次唤醒。
SYSTEM1_NATIVE_WAIT_SECONDS=3
# boot1 的真实麦克风 hw:0,2 会被 mipns-xiaomi 占用。
# 实测临时 kill/restart mipns 做追问录音后，boot1 原生链路可能退化成“有唤醒应答但无 ASR/NLP”。
# 因此 boot1 默认关闭 LLM 连续追问，优先保证原生命令和首轮 LLM 稳定。
SYSTEM1_FOLLOWUP_ENABLED=0
SYSTEM1_FOLLOWUP_CAPTURE_MIPNS=0
SYSTEM1_FOLLOWUP_ASR_ENGINE=mac
SYSTEM1_FOLLOWUP_WINDOW_CAPTURE_DEV=hw:0,2
SYSTEM1_FOLLOWUP_WINDOW_CAPTURE_FORMAT=S32_LE
SYSTEM1_FOLLOWUP_WINDOW_CAPTURE_RATE=48000
SYSTEM1_FOLLOWUP_WINDOW_CAPTURE_CHANNELS=8
AIVS_LAB_INSTRUCTION_LOG=/tmp/mico_aivs_lab/instruction.log
AIVS_LAB_LOOKBACK_LINES=40
DIRECT_LLM_QUERY_PATTERNS="DEEPSEEK|DeepSeek|deepseek"

# 小米原生结构化路由。
# 优先使用 domain/action 判断路由，不用文本关键词猜测是否家电控制。
NATIVE_SUCCESS_DOMAINS="smartMiot soundboxControl time weather music player alarm timer system volume"
UNSUPPORTED_PATTERNS="暂时|不会|不支持|回答不上|需要再学习|没听懂|不知道|不会这项技能"

# 小米原生成功播报。
# 开启 think 阶段 freeze 后，原生成功结果的 speak 会由脚本手动 replay。
NATIVE_REPLAY_SUCCESS_SPEAK=1
NATIVE_REPLAY_SUCCESS_DELAY=0
# 如果上一轮“开灯/关灯/天气”等原生成功播报还没播出或刚进入播放队列，
# 此时用户再次唤醒“小爱同学”，就取消上一轮控制类成功播报，避免新一轮对话里听到旧的“开啦/关啦”。
# 默认只覆盖控制类 domain，不覆盖天气、时间这类纯语音回答。
NATIVE_REPLAY_CANCEL_ON_WAKE=1
NATIVE_REPLAY_CANCEL_DOMAINS="smartMiot soundboxControl volume system"
NATIVE_REPLAY_CANCEL_GRACE=0.2
NATIVE_REPLAY_CANCEL_WINDOW=4

# LLM 播放后的连续追问监听。
# 不要在 LLM 播放期间真正开始检测录音，否则音箱会录到自己的声音。
# 追问 ASR 默认使用小米原生 ai_service。该接口要求追问录音为 16k/单声道/S16_LE wav。
AUDIO_CAPTURE_SETUP=auto
FOLLOWUP_ENABLED=1
# 追问模式：
# - local_record：脚本本地录音，再送小米 ai_service 或 Mac ASR。boot0 可用，boot1 不稳定。
# - native_multirounds：实验模式，不本地录音；尝试复用小米原生连续对话，把 instruction.log 中的新 ASR 文本转给 LLM。
FOLLOWUP_MODE=local_record
# native_multirounds 模式下，等待小米原生 ASR 写入追问文本的最长时间和轮询间隔。
NATIVE_FOLLOWUP_POLL_SECONDS=12
NATIVE_FOLLOWUP_POLL_INTERVAL=0.2
# native_multirounds 模式下，向 mipns 标记预备连续对话，并在 LLM 播放前后通知本地 TTS 状态。
NATIVE_FOLLOWUP_PRE_MULTIROUNDS=1
NATIVE_FOLLOWUP_TTS_NOTIFY=1
# native_multirounds 探索项：LLM 播放结束后，再强制触发一次 multirounds。
# 用于验证“小米原生链路是否只在 TTS 结束后才重新开麦”。
NATIVE_FOLLOWUP_TRIGGER_AFTER_TTS_END=0
# native_multirounds 触发方式：
# - pns：只发 pnshelper pre_multirounds 事件。
# - pns6：发 mibrain_service 字符串中出现过的 pnshelper event=6。
# - oneshot：调用 pnshelper oneshot_set open=true。
# - wakeup：只调用原生 wakeup.sh multirounds。
# - both：两者都做，用于 boot1 探索验证。
# - both6：pns6 + wakeup。
NATIVE_FOLLOWUP_MULTIROUNDS_TRIGGER=pns
FOLLOWUP_TIMEOUT=8
FOLLOWUP_PREARM=1
FOLLOWUP_PREARM_EXTRA=3
FOLLOWUP_ARM_DELAY=0.2
FOLLOWUP_ASR_ENGINE=native
FOLLOWUP_NATIVE_ASR_TIMEOUT=30
FOLLOWUP_NATIVE_ASR_FALLBACK_MAC=0
FOLLOWUP_NATIVE_MIN_QUERY_BYTES=10
FOLLOWUP_RECORD_MODE=window
FOLLOWUP_WINDOW_SECONDS=5
FOLLOWUP_WINDOW_CAPTURE_DEV=Capture
FOLLOWUP_WINDOW_CAPTURE_FORMAT=S16_LE
FOLLOWUP_WINDOW_CAPTURE_RATE=16000
FOLLOWUP_WINDOW_CAPTURE_CHANNELS=1
FOLLOWUP_WINDOW_MIN_PEAK=300
FOLLOWUP_WINDOW_MIN_RMS_THRESHOLD=40
FOLLOWUP_WINDOW_MIN_ACTIVE_PERMILLE=5
FOLLOWUP_THRESHOLD=180
FOLLOWUP_START_HITS=1
FOLLOWUP_END_THRESHOLD=100
FOLLOWUP_START_RMS_THRESHOLD=115
FOLLOWUP_END_RMS_THRESHOLD=60
FOLLOWUP_START_ACTIVE_PERMILLE=80
FOLLOWUP_END_ACTIVE_PERMILLE=20
FOLLOWUP_IGNORE_INITIAL_CHUNKS=2
FOLLOWUP_TAIL_RMS_THRESHOLD=70
FOLLOWUP_TAIL_ACTIVE_PERMILLE=30
FOLLOWUP_SILENCE_LIMIT=3
FOLLOWUP_MIN_RAW_BYTES=16000

# LLM fallback 期间的小米原生播报抑制。
STOP_NATIVE_SECONDS=15
FREEZE_NATIVE_PLAYER_ON_FALLBACK=1
FREEZE_NATIVE_PLAYER_ON_THINK=1

# LLM 对话期间是否暂停小米原生 ASR 进程 mipns-xiaomi。
# 默认不要暂停。暂停可能会影响麦克风前端，导致追问录音只有噪声或近似静音。
# 如果后续确认原生小爱会抢占追问，再临时改成 1 做对比验证。
PAUSE_NATIVE_ASR_DURING_LLM=0

# 默认关闭重复请求抑制。只有观察到原生结果重复回放时再开启。
SUPPRESS_DUP_SECONDS=0
